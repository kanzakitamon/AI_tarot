{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "module": "esnext",
    "lib": [
      "es2015",
      "es2017",
      "es2018",
      "es2019",
      "es2020",
      "esnext"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@core/*": [
        "./packages/core/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "**/AppData/**",
    "**/History/**",
    "**/.cursor/**"
  ]
}
