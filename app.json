{
  "expo": {
    "name": "タロット占い - 悩みを文章で鑑定",
    "slug": "tarot-reading-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tarotreading.app"
    },
    "android": {
      "package": "com.tarotreading.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-sqlite",
        {
          "enableForExpoGo": true
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4764153276310493~2755952356",
          "androidAppId": "ca-app-pub-4764153276310493~5276806931"
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#5C6CFF"
        }
      ]
    ],
    "scheme": "tarot-reading",
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "b5cc19a7-13b3-4f2c-965d-5965973209a2"
      }
    }
  }
}
